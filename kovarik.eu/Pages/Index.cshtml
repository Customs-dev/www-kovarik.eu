@page
@model IndexModel
@{
    ViewData["Title"] = Localizer["Site_Title_Home"].Value;
    ViewData["MetaDescription"] = Localizer["Site_MetaDescription_Home"].Value;
}

@section Head {
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "Person",
        "name": "Mgr. Roman Kovařík",
        "url": "https://kovarik.eu",
        "jobTitle": ".NET Developer",
        "description": "@Html.Raw(Localizer["Site_MetaDescription_Home"].Value.Replace("\"", "\\\""))",
        "knowsAbout": [".NET", "C#", "ASP.NET Core", "Angular", "TypeScript", "AI", "Azure", "SQL Server", "MVC", "Razor Pages"],
        "address": {
            "@@type": "PostalAddress",
            "addressCountry": "CZ"
        },
        "sameAs": [
            "https://github.com/customs-dev"
        ]
    }
    </script>
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebSite",
        "name": "kovarik.eu",
        "url": "https://kovarik.eu",
        "description": "@Html.Raw(Localizer["Site_MetaDescription_Home"].Value.Replace("\"", "\\\""))",
        "inLanguage": "@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
    }
    </script>
}

<!-- ============================ HERO ============================ -->
<section id="hero" class="hero-section">
    <canvas id="particleCanvas"></canvas>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <p class="hero-label fade-in">@Localizer["Hero_Welcome"]</p>
                <h1 class="hero-name fade-in fade-in-delay-1">Mgr. Roman<br />Kovařík</h1>
                <p class="hero-title fade-in fade-in-delay-2">
                    <span id="typingText"
                          data-phrases="@Localizer["Hero_Typing_1"]|@Localizer["Hero_Typing_2"]|@Localizer["Hero_Typing_3"]|@Localizer["Hero_Typing_4"]|@Localizer["Hero_Typing_5"]"></span><span class="typing-cursor"></span>
                </p>
                <p class="hero-description fade-in fade-in-delay-3">
                    @Localizer["Hero_Description"]
                </p>
                <div class="d-flex gap-3 flex-wrap fade-in fade-in-delay-4">
                    <a href="#contact" class="btn btn-accent">
                        <i class="fa-solid fa-paper-plane me-2"></i>@Localizer["Hero_Btn_Contact"]
                    </a>
                    <a href="#projects" class="btn btn-outline-accent">
                        <i class="fa-solid fa-code me-2"></i>@Localizer["Hero_Btn_Projects"]
                    </a>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="hero-code-block fade-in fade-in-delay-2">
                    <div class="code-dots">
                        <span></span><span></span><span></span>
                    </div>
                    <code>
                        <span class="code-keyword">public class</span> <span class="code-type">Developer</span><br />
                        <span class="code-bracket">{</span><br />
                        &nbsp;&nbsp;<span class="code-keyword">public string</span> <span class="code-property">Name</span> => <span class="code-string">"Roman Kovařík"</span>;<br />
                        &nbsp;&nbsp;<span class="code-keyword">public string</span> <span class="code-property">Title</span> => <span class="code-string">"Mgr."</span>;<br />
                        &nbsp;&nbsp;<span class="code-keyword">public string[]</span> <span class="code-property">Skills</span> =><br />
                        &nbsp;&nbsp;&nbsp;&nbsp;[<span class="code-string">".NET"</span>, <span class="code-string">"Angular"</span>, <span class="code-string">"AI"</span>];<br />
                        &nbsp;&nbsp;<span class="code-keyword">public bool</span> <span class="code-property">LovesToCode</span> => <span class="code-keyword">true</span>;<br />
                        <span class="code-bracket">}</span>
                    </code>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================ ABOUT ============================ -->
<section id="about" class="section-alt">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <span class="section-label fade-in">@Localizer["About_Label"]</span>
                <h2 class="section-title fade-in">@Localizer["About_Title"]</h2>
                <hr class="section-divider fade-in" />
                <div class="about-text fade-in">
                    <p>@Localizer["About_P1"]</p>
                    <p>@Localizer["About_P2"]</p>
                    <p>@Localizer["About_P3"]</p>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="about-highlights fade-in">
                    <div class="highlight-item">
                        <span class="highlight-number">@Localizer["About_Highlight1_Number"]</span>
                        <span class="highlight-label">@Localizer["About_Highlight1_Label"]</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">@Localizer["About_Highlight2_Number"]</span>
                        <span class="highlight-label">@Localizer["About_Highlight2_Label"]</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">@Localizer["About_Highlight3_Number"]</span>
                        <span class="highlight-label">@Localizer["About_Highlight3_Label"]</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">@Localizer["About_Highlight4_Number"]</span>
                        <span class="highlight-label">@Localizer["About_Highlight4_Label"]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================ SKILLS ============================ -->
<section id="skills">
    <div class="container">
        <span class="section-label fade-in">@Localizer["Skills_Label"]</span>
        <h2 class="section-title fade-in">@Localizer["Skills_Title"]</h2>
        <p class="section-subtitle fade-in">@Localizer["Skills_Subtitle"]</p>

        <div class="row">
            <div class="col-lg-6">
                <div class="skill-category fade-in">
                    <h3 class="skill-category-title"><i class="fa-solid fa-server"></i> @Localizer["Skill_Cat_Backend"]</h3>
                    <div class="skill-tags">
                        <span class="skill-tag">C#</span>
                        <span class="skill-tag">.NET 10</span>
                        <span class="skill-tag">ASP.NET Core</span>
                        <span class="skill-tag">Razor Pages</span>
                        <span class="skill-tag">MVC</span>
                        <span class="skill-tag">Web API</span>
                        <span class="skill-tag">Entity Framework</span>
                        <span class="skill-tag">LINQ</span>
                        <span class="skill-tag">SignalR</span>
                    </div>
                </div>

                <div class="skill-category fade-in">
                    <h3 class="skill-category-title"><i class="fa-solid fa-palette"></i> @Localizer["Skill_Cat_Frontend"]</h3>
                    <div class="skill-tags">
                        <span class="skill-tag">Angular</span>
                        <span class="skill-tag">TypeScript</span>
                        <span class="skill-tag">JavaScript</span>
                        <span class="skill-tag">HTML5 / CSS3</span>
                        <span class="skill-tag">Bootstrap</span>
                        <span class="skill-tag">RxJS</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="skill-category fade-in">
                    <h3 class="skill-category-title"><i class="fa-solid fa-brain"></i> @Localizer["Skill_Cat_AI"]</h3>
                    <div class="skill-tags">
                        <span class="skill-tag">Azure OpenAI</span>
                        <span class="skill-tag">GitHub Copilot</span>
                        <span class="skill-tag">Docker</span>
                    </div>
                </div>

                <div class="skill-category fade-in">
                    <h3 class="skill-category-title"><i class="fa-solid fa-database"></i> @Localizer["Skill_Cat_Data"]</h3>
                    <div class="skill-tags">
                        <span class="skill-tag">SQL Server</span>
                        <span class="skill-tag">PostgreSQL</span>
                        <span class="skill-tag">Git</span>
                        <span class="skill-tag">GitHub</span>
                        <span class="skill-tag">CI/CD</span>
                        <span class="skill-tag">Visual Studio</span>
                        <span class="skill-tag">VS Code</span>
                        <span class="skill-tag">Rider</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================ EXPERIENCE ============================ -->
<section id="experience" class="section-alt">
    <div class="container">
        <div class="row">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <span class="section-label fade-in">@Localizer["Exp_Label"]</span>
                <h2 class="section-title fade-in">@Localizer["Exp_Title"]</h2>
                <hr class="section-divider fade-in" />
                <p class="section-subtitle fade-in" style="max-width: none;">
                    @Localizer["Exp_Subtitle"]
                </p>
            </div>
            <div class="col-lg-6 offset-lg-1">
                <div class="timeline fade-in">
                    <div class="timeline-item">
                        <span class="timeline-period">@Localizer["Exp_Period1"]</span>
                        <h4 class="timeline-role">@Localizer["Exp_Role1"]</h4>
                        <p class="timeline-company">@Localizer["Exp_Company1"]</p>
                        <p class="timeline-desc">@Localizer["Exp_Desc1"]</p>
                    </div>

                    <div class="timeline-item">
                        <span class="timeline-period">@Localizer["Exp_Period2"]</span>
                        <h4 class="timeline-role">@Localizer["Exp_Role2"]</h4>
                        <p class="timeline-company">@Localizer["Exp_Company2"]</p>
                        <p class="timeline-desc">@Localizer["Exp_Desc2"]</p>
                    </div>

                    <div class="timeline-item">
                        <span class="timeline-period">@Localizer["Exp_Period3"]</span>
                        <h4 class="timeline-role">@Localizer["Exp_Role3"]</h4>
                        <p class="timeline-company">@Localizer["Exp_Company3"]</p>
                        <p class="timeline-desc">@Localizer["Exp_Desc3"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================ PROJECTS ============================ -->
<section id="projects">
    <div class="container">
        <span class="section-label fade-in">@Localizer["Proj_Label"]</span>
        <h2 class="section-title fade-in">@Localizer["Proj_Title"]</h2>
        <p class="section-subtitle fade-in">@Localizer["Proj_Subtitle"]</p>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4 fade-in fade-in-delay-1">
                <div class="project-card">
                    <div class="project-icon"><i class="fa-solid fa-globe"></i></div>
                    <h4>@Localizer["Proj1_Title"]</h4>
                    <p>@Localizer["Proj1_Desc"]</p>
                    <div class="project-tech">
                        <span>.NET 10</span><span>Razor Pages</span><span>Bootstrap 5</span><span>CSS3</span>
                    </div>
                    <a href="https://github.com/customs-dev/www-kovarik.eu" target="_blank" rel="noopener" class="btn btn-sm btn-outline-accent mt-3">
                        <i class="fa-brands fa-github me-1"></i>@Localizer["Proj_Btn_GitHub"]
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 fade-in fade-in-delay-2">
                <div class="project-card">
                    <div class="project-icon"><i class="fa-solid fa-building"></i></div>
                    <h4>@Localizer["Proj2_Title"]</h4>
                    <p>@Localizer["Proj2_Desc"]</p>
                    <div class="project-tech">
                        <span>Angular</span><span>ASP.NET Core</span><span>SQL Server</span><span>Azure</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 fade-in fade-in-delay-3">
                <div class="project-card">
                    <div class="project-icon"><i class="fa-solid fa-robot"></i></div>
                    <h4>@Localizer["Proj3_Title"]</h4>
                    <p>@Localizer["Proj3_Desc"]</p>
                    <div class="project-tech">
                        <span>Azure OpenAI</span><span>Semantic Kernel</span><span>C#</span><span>.NET</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 fade-in fade-in-delay-4">
                <div class="project-card">
                    <div class="project-icon"><i class="fa-solid fa-bicycle"></i></div>
                    <h4>@Localizer["Proj4_Title"]</h4>
                    <p>@Localizer["Proj4_Desc"]</p>
                    <div class="project-tech">
                        <span>AI</span><span>OpenStreetMap</span><span>@Localizer["Proj4_Tag1"]</span><span>@Localizer["Proj4_Tag2"]</span>
                    </div>
                    <a href="https://home832.myds.me" target="_blank" rel="noopener" class="btn btn-sm btn-outline-accent mt-3">
                        <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>@Localizer["Proj_Btn_Launch"]
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 fade-in fade-in-delay-5">
                <div class="project-card">
                    <div class="project-icon"><i class="fa-solid fa-stopwatch"></i></div>
                    <h4>@Localizer["Proj5_Title"]</h4>
                    <p>@Localizer["Proj5_Desc"]</p>
                    <div class="project-tech">
                        <span>Kotlin</span><span>Jetpack Compose</span><span>CameraX</span><span>AI / Gemini</span>
                    </div>
                    <a href="https://github.com/Customs-dev/WatchDriftAndroidApp" target="_blank" rel="noopener" class="btn btn-sm btn-outline-accent mt-3">
                        <i class="fa-brands fa-github me-1"></i>@Localizer["Proj_Btn_GitHub"]
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 fade-in fade-in-delay-6">
                <div class="project-card">
                    <div class="project-icon"><i class="fa-solid fa-microphone"></i></div>
                    <h4>@Localizer["Proj6_Title"]</h4>
                    <p>@Localizer["Proj6_Desc"]</p>
                    <div class="project-tech">
                        <span>.NET 9</span><span>WinForms</span><span>Whisper</span><span>WebSocket</span><span>Vulkan</span>
                    </div>
                    <a href="https://github.com/Customs-dev/STT-Whisper-Dotnet-APP" target="_blank" rel="noopener" class="btn btn-sm btn-outline-accent mt-3">
                        <i class="fa-brands fa-github me-1"></i>@Localizer["Proj_Btn_GitHub"]
                    </a>
