</section>

<!-- ============================ CONTACT ============================ -->
<section id="contact" class="section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-label fade-in">@Localizer["Contact_Label"]</span>
            <h2 class="section-title fade-in">@Localizer["Contact_Title"]</h2>
            <p class="section-subtitle fade-in mx-auto">@Localizer["Contact_Subtitle"]</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-sm-6 col-lg-3 fade-in fade-in-delay-1">
                <div class="contact-card">
                    <i class="fa-solid fa-envelope"></i>
                    <h5>@Localizer["Contact_Email_Label"]</h5>
                    <a href="mailto:roman@kovarik.eu">roman&#64;kovarik.eu</a>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3 fade-in fade-in-delay-3">
                <div class="contact-card">
                    <i class="fa-brands fa-github"></i>
                    <h5>@Localizer["Contact_GitHub_Label"]</h5>
                    <a href="https://github.com/customs-dev" target="_blank" rel="noopener">@Localizer["Contact_GitHub_Link"]</a>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3 fade-in fade-in-delay-4">
                <div class="contact-card">
                    <i class="fa-solid fa-location-dot"></i>
                    <h5>@Localizer["Contact_Location_Label"]</h5>
                    <p class="mb-0">@Localizer["Contact_Location_Value"]</p>
                </div>
            </div>
        </div>
    </div>
</section>
