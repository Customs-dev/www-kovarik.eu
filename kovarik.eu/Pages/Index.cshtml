@page
@model IndexModel
@{
    ViewData["Title"] = "Osobní webová prezentace";
    ViewData["MetaDescription"] = "Mgr. Roman Kovařík — zkušený .NET vývojář. Specializace na ASP.NET Core, Angular, MVC, C# a integraci umělé inteligence do webových aplikací.";
}

@section Head {
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "Person",
        "name": "Mgr. Roman Kovařík",
        "url": "https://kovarik.eu",
        "jobTitle": ".NET Developer",
        "description": "Zkušený .NET vývojář specializující se na webové aplikace, ASP.NET Core, Angular, MVC architekturu a AI integraci.",
        "knowsAbout": [".NET", "C#", "ASP.NET Core", "Angular", "TypeScript", "AI", "Azure", "SQL Server", "MVC", "Razor Pages"],
        "address": {
            "@@type": "PostalAddress",
            "addressCountry": "CZ"
        },
        "sameAs": [
            "https://github.com/customs-dev"
        ]
    }
    </script>
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebSite",
        "name": "kovarik.eu",
        "url": "https://kovarik.eu",
        "description": "Osobní webová prezentace Mgr. Romana Kovaříka — .NET Developer & AI Enthusiast",
        "inLanguage": "cs"
    }
    </script>
}

<!-- ============================
     HERO SECTION
     ============================ -->
<section id="hero" class="hero-section">
    <canvas id="particleCanvas"></canvas>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <p class="hero-label fade-in">// Vítejte na mém webu</p>
                <h1 class="hero-name fade-in fade-in-delay-1">Mgr. Roman<br />Kovařík</h1>
                <p class="hero-title fade-in fade-in-delay-2">
                    <span id="typingText"></span><span class="typing-cursor"></span>
                </p>
                <p class="hero-description fade-in fade-in-delay-3">
                    Specializuji se na vývoj webových aplikací postavených na platformě .NET,
                    MVC architektuře, Angular SPA a integraci umělé inteligence do moderních řešení.
                </p>
                <div class="d-flex gap-3 flex-wrap fade-in fade-in-delay-4">
                    <a href="#contact" class="btn btn-accent">
                        <i class="fa-solid fa-paper-plane me-2"></i>Kontaktujte mě
                    </a>
                    <a href="#projects" class="btn btn-outline-accent">
                        <i class="fa-solid fa-code me-2"></i>Moje projekty
                    </a>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="hero-code-block fade-in fade-in-delay-2">
                    <div class="code-dots">
                        <span></span><span></span><span></span>
                    </div>
                    <code>
                        <span class="code-keyword">public class</span> <span class="code-type">Developer</span><br />
                        <span class="code-bracket">{</span><br />
                        &nbsp;&nbsp;<span class="code-keyword">public string</span> <span class="code-property">Name</span> => <span class="code-string">"Roman Kovařík"</span>;<br />
                        &nbsp;&nbsp;<span class="code-keyword">public string</span> <span class="code-property">Title</span> => <span class="code-string">"Mgr."</span>;<br />
                        &nbsp;&nbsp;<span class="code-keyword">public string[]</span> <span class="code-property">Skills</span> =><br />
                        &nbsp;&nbsp;&nbsp;&nbsp;[<span class="code-string">".NET"</span>, <span class="code-string">"Angular"</span>, <span class="code-string">"AI"</span>];<br />
                        &nbsp;&nbsp;<span class="code-keyword">public bool</span> <span class="code-property">LovesToCode</span> => <span class="code-keyword">true</span>;<br />
                        <span class="code-bracket">}</span>
                    </code>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================
     O MNĚ
     ============================ -->
<section id="about" class="section-alt">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <span class="section-label fade-in">// O mně</span>
                <h2 class="section-title fade-in">Kdo jsem</h2>
                <hr class="section-divider fade-in" />
                <div class="about-text fade-in">
                    <p>
                        Jsem zkušený softwarový vývojář se zaměřením na technologie .NET a moderní
                        webový vývoj. Mám za sebou roky praxe v návrhu a implementaci webových
                        aplikací — od firemních informačních systémů po veřejné internetové prezentace.
                    </p>
                    <p>
                        V současné době se intenzivně věnuji integraci AI nástrojů do vývojového
                        procesu a snažím se propojit klasický enterprise vývoj s možnostmi,
                        které nabízí velké jazykové modely a služby jako OpenAI, Anthropic a další.
                    </p>
                    <p>
                        Kromě vývoje mám zkušenosti s vedením menších týmů, code review,
                        CI/CD pipeline a architektonickým designem aplikací.
                    </p>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="about-highlights fade-in">
                    <div class="highlight-item">
                        <span class="highlight-number">30+</span>
                        <span class="highlight-label">Let v IT</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">.NET</span>
                        <span class="highlight-label">Primární stack</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">AI</span>
                        <span class="highlight-label">Integrace</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">Web</span>
                        <span class="highlight-label">Aplikace</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

