        <div class="row">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <span class="section-label fade-in">// Zkušenosti</span>
                <h2 class="section-title fade-in">Profesní kariéra</h2>
                <hr class="section-divider fade-in" />
