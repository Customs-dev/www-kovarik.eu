@page
@model PrivacyModel
@{
    ViewData["Title"] = Localizer["Privacy_Title"].Value;
    ViewData["MetaDescription"] = Localizer["Privacy_MetaDescription"].Value;
}

<section class="py-5 mt-5">
    <div class="container" style="max-width: 800px;">
        <h1 class="section-title mb-4">@Localizer["Privacy_Title"]</h1>
        <hr class="section-divider" />

        <div class="about-text">
            <p>@Localizer["Privacy_P1"]</p>
            <p>@Localizer["Privacy_P2"]</p>
            <p>
                <a href="/" class="btn btn-outline-accent mt-3">
                    <i class="fa-solid fa-arrow-left me-2"></i>@Localizer["Privacy_BackHome"]
                </a>
            </p>
        </div>
    </div>
</section>
